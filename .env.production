# ============================================================
#  AI Call Center — Production .env
#  Copy this to .env and fill in your real values
# ============================================================

# ---------- DATABASE ----------
# If using Docker Compose, these connect to the containers:
DATABASE_URL=postgresql://user:password@postgres:5432/ai_agent_db
MONGODB_URL=mongodb://mongodb:27017/ai_agent_logs
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# If running Prisma from the HOST (migrations), use localhost:
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_agent_db

# ---------- AI API KEYS (REQUIRED) ----------
OPENAI_API_KEY=sk-your-openai-key-here
DEEPGRAM_API_KEY=your-deepgram-key-here
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# ---------- TELEPHONY (REQUIRED for voice calls) ----------
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ---------- AWS S3 (for recordings) ----------
S3_BUCKET=ai-agent-recordings
S3_REGION=us-east-1
S3_ACCESS_KEY=your-aws-access-key
S3_SECRET_KEY=your-aws-secret-key

# ---------- EMAIL (pick one) ----------
# Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourcompany.com

# OR SendGrid
# SENDGRID_API_KEY=SG.xxxx

# ---------- WHATSAPP (optional) ----------
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# ---------- IVR ----------
RECORDING_CONSENT=true

# ---------- JWT ----------
JWT_SECRET=change-this-to-a-random-64-char-string

# ---------- SERVICE PORTS (don't change unless needed) ----------
API_GATEWAY_PORT=3000
VOICE_SERVICE_PORT=3001
TOOL_EXECUTION_PORT=3002
RECORDING_SERVICE_PORT=3003
ADMIN_SERVICE_PORT=3004
AI_ENGINE_PORT=8000
ANALYTICS_SERVICE_PORT=8001
QA_SERVICE_PORT=8002
KNOWLEDGE_BASE_PORT=3008
TRANSFER_SERVICE_PORT=3009
IVR_SERVICE_PORT=3010
SMS_SERVICE_PORT=3011
SENTIMENT_SERVICE_PORT=3012
EMAIL_SERVICE_PORT=3013
WHATSAPP_SERVICE_PORT=3014
BILLING_SERVICE_PORT=3015
CAMPAIGNS_SERVICE_PORT=3016
VOICEMAIL_SERVICE_PORT=3017
QUEUE_SERVICE_PORT=3018
MONITORING_SERVICE_PORT=3019
SURVEY_SERVICE_PORT=3020

# ---------- SERVICE URLS (Docker internal) ----------
API_URL=http://api-gateway:3000
AI_ENGINE_URL=http://ai-engine-service:8000
TRANSFER_SERVICE_URL=http://transfer-service:3009
VOICE_SERVICE_URL=http://voice-service:3001
SMS_SERVICE_URL=http://sms-service:3011
EMAIL_SERVICE_URL=http://email-service:3013
ADMIN_SERVICE_URL=http://admin-service:3004

# ---------- FRONTEND ----------
NEXT_PUBLIC_API_URL=http://YOUR_EC2_PUBLIC_IP:3000
FRONTEND_URL=http://YOUR_EC2_PUBLIC_IP:3021
